{
	"name": "mimirmesh",
	"version": "0.1.0",
	"private": true,
	"license": "MIT",
	"type": "module",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"format": "bunx @biomejs/biome format --write .",
		"lint": "bunx @biomejs/biome lint .",
		"check": "bunx @biomejs/biome check .",
		"typecheck": "bunx tsc --noEmit",
		"build": "bun run scripts/build.ts",
		"release:assets": "bun run scripts/release-assets.ts",
		"release": "GITHUB_TOKEN=$(gh auth token) bunx release-it",
		"test": "bun run test:packages && bun run test:apps",
		"test:packages": "bun test packages",
		"test:apps": "bun test apps",
		"test:unit": "bun test packages apps",
		"test:integration": "bun run scripts/run-integration-tests.ts",
		"validate": "bun run check && bun run test && bun run build",
		"prepare": "husky"
	},
	"dependencies": {
		"@inkjs/ui": "^2.0.0",
		"@modelcontextprotocol/sdk": "^1.27.1",
		"ink": "^6.8.0",
		"pastel": "^4.0.1",
		"react": "^19.2.4",
		"react-devtools-core": "^7.0.1",
		"yaml": "^2.8.3",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@release-it/conventional-changelog": "^10.0.6",
		"@types/bun": "1.3.11",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"conventional-changelog-conventionalcommits": "^9.3.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"release-it": "^19.2.4",
		"typescript": "^6.0.2"
	},
	"release-it": {
		"hooks": {
			"before:init": "bun run test",
			"before:github:release": "bun run build && bun run release:assets"
		},
		"git": {
			"commitMessage": "chore: release v${version}",
			"pushRepo": "origin",
			"requireBranch": "main",
			"requireCommits": true
		},
		"github": {
			"release": true,
			"assets": [
				"dist/releases/*.tar.gz",
				"dist/releases/install.sh",
				"dist/releases/checksums.txt"
			]
		},
		"npm": {
			"publish": false
		},
		"plugins": {
			"@release-it/conventional-changelog": {
				"preset": "angular",
				"infile": "docs/changelog.md"
			}
		}
	}
}
